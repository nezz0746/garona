# Server
NODE_ENV=production
PORT=3001

# Database
DATABASE_URL=postgresql://user:password@host:5432/garona

# Authentication (BetterAuth)
BETTER_AUTH_URL=https://api.garona.econome.studio
PASSKEY_RP_ID=garona.city
PASSKEY_ORIGIN=https://garona.econome.studio

# S3 / Object Storage
S3_ENDPOINT=https://your-s3-endpoint.com
S3_BUCKET=garona
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# Public URL (used to generate accessible URLs for uploaded files)
PUBLIC_API_URL=https://api.garona.econome.studio
