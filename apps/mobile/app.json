{
  "expo": {
    "name": "Garona",
    "slug": "garona",
    "owner": "nino0746",
    "scheme": "garona",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "platforms": ["ios", "android", "web"],
    "ios": {
      "bundleIdentifier": "studio.econome.garona",
      "associatedDomains": ["webcredentials:garona.econome.studio"],
      "infoPlist": {
        "NSFaceIDUsageDescription": "Garona utilise Face ID pour sécuriser ton compte",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/icon-trans.png",
          "imageWidth": 128
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Garona utilise Face ID pour sécuriser ton compte"
        }
      ],
      "expo-web-browser",
      "expo-notifications",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "garona",
          "organization": "astroblock"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1d388319-75e6-4cf9-8dcf-5411976a918d"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/1d388319-75e6-4cf9-8dcf-5411976a918d"
    },
    "android": {
      "package": "studio.econome.garona",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    }
  }
}
