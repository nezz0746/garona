{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "dev": { "cache": false, "persistent": true },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".expo/**", "dist/**"],
      "passThroughEnv": [
        "BETTER_AUTH_URL",
        "PASSKEY_RP_ID",
        "PASSKEY_ORIGIN",
        "DATABASE_URL",
        "S3_ENDPOINT",
        "S3_BUCKET",
        "S3_ACCESS_KEY",
        "S3_SECRET_KEY",
        "PUBLIC_API_URL"
      ]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "BETTER_AUTH_URL",
        "PASSKEY_RP_ID",
        "PASSKEY_ORIGIN",
        "DATABASE_URL",
        "S3_ENDPOINT",
        "S3_BUCKET",
        "S3_ACCESS_KEY",
        "S3_SECRET_KEY",
        "PUBLIC_API_URL"
      ]
    },
    "lint": {},
    "check": { "cache": false },
    "check:fix": { "cache": false }
  }
}
